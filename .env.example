# 复制为 .env 并填入真实值（.env 已在 .gitignore，勿提交）

# ---- 阿里云短信（签名「恒创联众」/ 登录注册模板）----
# ⚠ 建议用 RAM 子账号的 AccessKey，只授予 AliyunDysmsFullAccess 权限，不要用主账号 key
ALIYUN_SMS_KEY_ID=LTAI5tDo2rkRcY6zoqUbC4Gg
ALIYUN_SMS_KEY_SECRET=在这里填AccessKeySecret
ALIYUN_SMS_SIGN_NAME=恒创联众
ALIYUN_SMS_TEMPLATE_CODE=100001
# 该模板含 ${code} 与 ${min} 两个变量；${code} 会被替换为真实验证码，有效期与后端 OTP 一致=5 分钟
ALIYUN_SMS_TEMPLATE_JSON={"code":"${code}","min":"5"}

# ---- 通义千问（语音解析 / ASR 中继）----
DASHSCOPE_API_KEY=sk-xxxx
QWEN_MODEL=qwen-turbo

# ---- 生产部署才需要（本地 npm run dev 用内存 MongoDB，可不填）----
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/peoplenet
# JWT_SECRET=change-me
# PORT=3000

MOCK_OTP=false
